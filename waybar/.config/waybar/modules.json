{
  "custom/arch": {
    "format": "¾░Żć",
    "tooltip": true,
    "tooltip-format": "btw"
  },


  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "warp-on-scroll": false,
    "show-special": true,
    "special-visible-only": true,
    "format": "{name}",
    "format-icons": {
      "urgent": "’ü¬",
      "active": "’åÆ",
      "default": "’äæ"
    }
  },
  "hyprland/window": {
    "icon": true,
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "’ü«",
      "deactivated": "’ü░"
    }
  },
  "custom/wireguard": {
    "exec": "exec ~/.local/bin/wireguard-manager.sh -s",
    "format": "{icon}",
    "format-icons": {
      "connected": "<span color=\"#50fa7b\">VPN ­¤öÆ</span>",
      "disconnected": "­¤öō",
    },
    "interval": "once",
    "on-click": "~/.local/bin/wireguard-manager.sh -t",
    "return-type": "json",
    "signal": 1,
  },
  "wireplumber": {
    "format": "{icon}   {volume}%",
    "format-muted": "’æ” ",
    "format-bluetooth": "{icon} {volume}% ’Ŗö",
    "format-bluetooth-muted": "’Ü® {icon}’Ŗö",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%+",
    "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%-",
    "scroll-step": 1,
    "format-icons": {
      "headphone": "’Ćź",
      "hands-free": "’Ćź",
      "headset": "’Ćź",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": ["’Ć”", "’Ć¦", "’Ć©"]
    },
    "tooltip": true,
    "tooltip-format": "{icon} at {volume}%"
  },

  "wireplumber#source": {
    "format": "{format_source} {source_volume}%",
    "format-source": "’ä░",
    "format-source-muted": "’ä▒",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 1%+",
    "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 1%-",
    "scroll-step": 1,
    "tooltip": true,
    "tooltip-format": "’ä░  at {source_volume}%"
  },

  "network": {
    "format-wifi": "’ć½ ",
    "format-ethernet": "’×¢   {ipaddr}/{cidr}",
    "tooltip-format": "SSID: {essid} \n if: {ifname} \n Gateway: {gwaddr}",
    "format-linked": "{ifname} (No IP) ’×¢",
    "format-disconnected": "Disconnected ŌÜĀ",
    "on-click": "kitty gazelle",
  },

  "cpu": {
    "format": "’ŗø  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "’āē  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
    "critical-threshold": 100,
    "format-critical": "’ŗć {temperatureC}",
    "format": "’ŗē {temperatureC}┬░C"
  },

  "hyprland/language": {
    "format": "’é¼  {}",
    "format-en": "EN",
    "format-ru": "RU"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-full": "{icon}",
    "format-charging": "¾▒Éŗ",
    "format-plugged": "’ć”",
    "format-alt": "{time}  {icon}",
    "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"],
    "tooltip-format": "Battery: {capacity}%\nTime remaining: {time}",
    "on-click": "~/.local/bin/waybar-battery.sh --menu"
  },
  "clock": {
    "format": "{:%m/%d | %I:%M %p}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "custom/power": {
    "format" : "’Ćæ ",
    "tooltip": false,
    "on-click": "rofi -show p -modi p:rofi-power-menu"
  },
  "custom/clipboard": {
    "on-click": "cliphist list | rofi -dmenu -display-columns 2 | cliphist decode | wl-copy",
    "on-click-right": "cliphist wipe && notify-send 'Clipboard history cleared'",
    "format": "¾░ģī",
    "tooltip-format": "Click to open clipboard history, right-click to clear"
  },
  "tray": {
    "icon-size": 12,
    "spacing": 10
  },
  "bluetooth": {
    "format": "’Ŗö",
    "format-disabled": "", // an empty format will hide the module
    "format-connected": "’Ŗö {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "kitty bluetui",
  },
  "custom/notification": {
    "exec": "swaync-client --subscribe-waybar",
    "on-click": "swaync-client --toggle-panel",
    "on-click-right": "swaync-client --toggle-dnd",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "none": "¾░éÜ ",
      "dnd": "¾░éø ",
      "notification": "¾▒ģ½ "
    }
  },
  "custom/media": {
    "format": "{}",
    "return-type": "json",
    "exec": "$HOME/.local/bin/spotify-now-playing.sh",
    "interval": 1,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  }
}
