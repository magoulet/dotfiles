{
  "custom/arch": {
    "format": "ґ░гЗ",
    "tooltip": true,
    "tooltip-format": "btw"
  },


  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "warp-on-scroll": false,
    "show-special": true,
    "special-visible-only": true,
    "format": "{name}",
    "format-icons": {
      "urgent": "яБк",
      "active": "яЖТ",
      "default": "яДС"
    }
  },
  "hyprland/window": {
    "icon": true,
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо",
      "deactivated": "яБ░"
    }
  },
  "custom/wireguard": {
    "exec": "exec ~/.local/bin/wireguard-manager.sh -s",
    "format": "{icon}",
    "format-icons": {
      "connected": "<span color=\"#50fa7b\">VPN ЁЯФТ</span>",
      "disconnected": "ЁЯФУ",
    },
    "interval": "once",
    "on-click": "~/.local/bin/wireguard-manager.sh -t",
    "return-type": "json",
    "signal": 1,
  },
  "wireplumber": {
    "format": "{icon}  {volume}%",
    "format-muted": "яСж ",
    "format-bluetooth": "{icon}{volume}% яКФ",
    "format-bluetooth-muted": "яЪй {icon}яКФ",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%+",
    "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SINK@ 1%-",
    "scroll-step": 1,
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яАе",
      "headset": "яАе",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАж", "яАз", "яАи"]
    },
    "tooltip": true,
    "tooltip-format": "{icon} at {volume}%"
  },

  "wireplumber#source": {
    "format": "{format_source}  {source_volume}%",
    "format-source": "яД░",
    "format-source-muted": "яД▒",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 1%+",
    "on-scroll-down": "wpctl set-volume -l 1 @DEFAULT_AUDIO_SOURCE@ 1%-",
    "scroll-step": 1,
    "tooltip": true,
    "tooltip-format": "яД░  at {source_volume}%"
  },

  "network": {
    "format-wifi": "яЗл ",
    "format-ethernet": "яЮЦ   {ipaddr}/{cidr}",
    "tooltip-format": "SSID: {essid} \n if: {ifname} \n Gateway: {gwaddr}",
    "format-linked": "{ifname} (No IP) яЮЦ",
    "format-disconnected": "Disconnected тЪа",
    "on-click": "kitty gazelle",
  },

  "cpu": {
    "format": "яЛЫ  {usage}%",
    "tooltip": true
  },
  "memory": {
    "format": "яГЙ  {}%",
    "tooltip": true
  },
  "temperature": {
    "interval": 10,
    "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon4/temp1_input",
    "critical-threshold": 100,
    "format-critical": "яЛЗ {temperatureC}",
    "format": "яЛЙ {temperatureC}┬░C"
  },

  "hyprland/language": {
    "format": "яВм  {}",
    "format-en": "EN",
    "format-ru": "RU"
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}",
    "format-full": "{icon}",
    "format-charging": "ґ▒РЛ",
    "format-plugged": "яЗж",
    "format-alt": "{time}  {icon}",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"],
    "tooltip-format": "Battery: {capacity}%\nTime remaining: {time}",
    "on-click": "~/.local/bin/waybar-battery.sh --menu"
  },
  "clock": {
    "format": "{:%m/%d | %I:%M %p}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "format-alt": "{:%Y-%m-%d}"
  },
  "custom/power": {
    "format" : "яАС ",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "$HOME/.config/waybar/power_menu.xml", 
    "menu-actions": {
      "lock": "hyprlock",
      "shutdown": "shutdown",
      "reboot": "reboot",
      "suspend": "systemctl suspend",
      "hibernate": "systemctl hibernate"
    }
  },
  "custom/clipboard": {
    "on-click": "cliphist list | rofi -dmenu -display-columns 2 | cliphist decode | wl-copy",
    "on-click-right": "cliphist wipe && notify-send 'Clipboard history cleared'",
    "format": "ґ░ЕМ",
    "tooltip-format": "Click to open clipboard history, right-click to clear"
  },
  "tray": {
    "icon-size": 12,
    "spacing": 10
  },
  "bluetooth": {
    "format": "яКФ",
    "format-disabled": "", // an empty format will hide the module
    "format-connected": "яКФ {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "kitty bluetui",
  },
  "custom/notification": {
    "exec": "swaync-client --subscribe-waybar",
    "on-click": "swaync-client --toggle-panel",
    "on-click-right": "swaync-client --toggle-dnd",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "none": "ґ░ВЪ ",
      "dnd": "ґ░ВЫ ",
      "notification": "ґ▒Ел "
    }
  },
  "custom/media": {
    "format": "{}",
    "return-type": "json",
    "exec": "$HOME/.local/bin/spotify-now-playing.sh",
    "interval": 1,
    "on-click": "playerctl play-pause",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  }
}
