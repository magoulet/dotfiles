{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "ls *": "allow",
      "which *": "allow",
      "td *": "allow"
    },
    "webfetch": "allow"
    },
  "instructions": [
    "~/.config/opencode/context/*.md"
  ],
  "mcp": {{- if eq .chezmoi.hostname "tars" }} {}
  {{- else }} {
    "google-calendar-mcp": {
      "type": "local",
      "command": [
        "npx",
        "@cocal/google-calendar-mcp"
      ],
      "environment": {
        "GOOGLE_OAUTH_CREDENTIALS": "/home/magoulet/.local/secure/google/mcp-oauth.json"
      },
      "timeout": 20000,
      "instructions": "Draft calendar events and present to user for review before creating. Do not post until user approves. Use actual newline characters in description fields, not escaped \\n strings."
    },
    "gmail": {
      "type": "local",
      "command": [
        "npx",
        "@gongrzhe/server-gmail-autoauth-mcp"
      ],
      "timeout": 20000,
      "instructions": "Draft emails and present to user for review before sending. Do not send until user approves."
    }
  }
  {{- end }}
}
