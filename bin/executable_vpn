#!/bin/bash

status_check() {
    if sudo wg show wg0 2>/dev/null | grep -q "interface: wg0"; then
        echo "WireGuard (wg0) is UP"
        echo "Current configuration:"
        sudo wg show wg0
    else
        echo "WireGuard (wg0) is DOWN"
    fi
}

case $1 in
    up)     sudo wg-quick up wg0 ;;
    down)   sudo wg-quick down wg0 ;;
    status) status_check ;;
    *)      echo "Usage: vpn up|down|status" ;;
esac
